{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lwriter",
  "version": "0.2.0",
  "identifier": "app.lwriter",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "lwriter",
        "width": 1100,
        "height": 760,
        "minWidth": 420,
        "minHeight": 300,
        "center": true,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "publisher": "lwriter",
    "shortDescription": "A calm, FOSS writing app for Windows",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
