{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "lwriter",
        "width": 1100,
        "height": 760,
        "minWidth": 420,
        "minHeight": 300,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "shortDescription": "A calm, FOSS writing app"
  }
}
